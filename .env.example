# =============================================================================
# Mi Proximo Hogar — variables de entorno
# Copia a .env y NUNCA subas .env a Git ni lo dejes en carpeta publica.
# =============================================================================

# --- OBLIGATORIO EN PRODUCCION ---
SECRET_KEY=genera-una-clave-larga-aleatoria-minimo-32-caracteres
FLASK_ENV=production
FLASK_DEBUG=0
SITE_URL=https://tudominio.pe

# --- DATOS LEGALES (politicas de privacidad / aviso legal) ---
LEGAL_ENTITY_NAME=Mi Proximo Hogar S.A.C.
LEGAL_RUC=20XXXXXXXXX
LEGAL_ADDRESS=Av. Ejemplo 123, Cusco, Peru
LEGAL_EMAIL=contacto@miproximohogar.pe
LEGAL_PHONE=+51 999 999 999

# --- MOTOR DE BASE DE DATOS ---
# Local (Windows + SQL Server):     DB_ENGINE=mssql
# Azure App Service + Azure SQL:    DB_ENGINE=mssql + DB_AZURE=yes
# Hostinger (MySQL):                DB_ENGINE=mysql

DB_ENGINE=mssql

# SQL Server local
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=MiProximoHogar
DB_TRUSTED_CONNECTION=yes

# Azure SQL (descomenta y completa en produccion)
# DB_DRIVER=ODBC Driver 18 for SQL Server
# DB_SERVER=tu-servidor.database.windows.net,1433
# DB_TRUSTED_CONNECTION=no
# DB_USER=sqladmin
# DB_PASSWORD=clave-segura
# DB_ENCRYPT=yes
# DB_TRUST_SERVER_CERTIFICATE=no
# DB_AZURE=yes

# MySQL Hostinger (solo si DB_ENGINE=mysql)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=u123456789_miph
# MYSQL_USER=u123456789_miph
# MYSQL_PASSWORD=clave-muy-segura-aqui

UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=33554432

GOOGLE_MAPS_API_KEY=tu-clave-maps
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://tudominio.pe/cuenta/google/callback

# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.xxxxx
# MAIL_DEFAULT_SENDER=Mi Proximo Hogar <no-reply@tudominio.pe>

PASSWORD_RESET_HOURS=2
